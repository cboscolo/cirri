{
	"name": "webfid-miniapp",
	"compatibility_date": "2025-12-02",
	"workers_dev": false,
	"preview_urls": false,
	"routes": [
		{ "pattern": "my.fid.is/*", "zone_name": "fid.is" }
	],
	"assets": {
		"directory": "./dist",
		"html_handling": "drop-trailing-slash",
		"not_found_handling": "single-page-application"
	}
}